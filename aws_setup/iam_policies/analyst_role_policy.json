{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListCuratedPrefixOnly",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::{{BUCKET_NAME}}",
      "Condition": { "StringLike": { "s3:prefix": ["curated/*"] } }
    },
    {
      "Sid": "ReadCuratedObjectsOnly",
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": "arn:aws:s3:::{{BUCKET_NAME}}/curated/*"
    }
  ]
}
