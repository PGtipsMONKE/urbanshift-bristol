--Operational risk 
--1 -incident rate and city 
SELECT
    d.city,
    ROUND(COUNT(i.incident_id) * 100.0 / COUNT(d.delivery_id), 2) AS incident_rate_percent
FROM urbanshift.deliveries d
LEFT JOIN urbanshift.incidents i
    ON d.delivery_id = i.delivery_id
GROUP BY d.city
ORDER BY incident_rate_percent DESC;

--2 incident rate and employment type
SELECT
    c.employment_type,
    COUNT(d.delivery_id) AS total_deliveries,
    COUNT(i.incident_id) AS total_incidents,
    ROUND(COUNT(i.incident_id) * 100.0 / COUNT(d.delivery_id), 2) AS incident_rate_percent
FROM urbanshift.deliveries d
JOIN urbanshift.couriers c
    ON d.courier_id = c.courier_id
LEFT JOIN urbanshift.incidents i
    ON d.delivery_id = i.delivery_id
GROUP BY c.employment_type
ORDER BY incident_rate_percent DESC;

--3 incident rate and shift pattern
SELECT
    c.shift_pattern,
    COUNT(d.delivery_id) AS total_deliveries,
    COUNT(i.incident_id) AS total_incidents,
    ROUND(COUNT(i.incident_id) * 100.0 / COUNT(d.delivery_id), 2) AS incident_rate_percent
FROM urbanshift.deliveries d
JOIN urbanshift.couriers c
    ON d.courier_id = c.courier_id
LEFT JOIN urbanshift.incidents i
    ON d.delivery_id = i.delivery_id
GROUP BY c.shift_pattern
ORDER BY incident_rate_percent DESC;


--4 incident rate, emplyment and shift pattern 
SELECT
    c.employment_type,
    c.shift_pattern,
    COUNT(d.delivery_id) AS total_deliveries,
    COUNT(i.incident_id) AS total_incidents,
    ROUND(COUNT(i.incident_id) * 100.0 / COUNT(d.delivery_id), 2) AS incident_rate_percent
FROM urbanshift.deliveries d
JOIN urbanshift.couriers c
    ON d.courier_id = c.courier_id
LEFT JOIN urbanshift.incidents i
    ON d.delivery_id = i.delivery_id
GROUP BY c.employment_type, c.shift_pattern
ORDER BY incident_rate_percent DESC;

